# Copie este arquivo para ".env.local" e preencha com os mesmos dados
# usados no painel administrativo e no app (Supabase → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# E-mail de confirmação de pedido (mesmos valores usados no app)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=seu-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=seu-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=sua-public-key
NEXT_PUBLIC_EMAILJS_PRIVATE_KEY=sua-private-key
